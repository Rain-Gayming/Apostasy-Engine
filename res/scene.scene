root_children:
- name: Node
  id: 0
  components:
  - type: ModelRenderer
    data:
      loaded_model: .engine/cube.glb
      material_path: materials/material.material
  - type: Transform
    data:
      position:
        x: 0.0
        y: 0.0
        z: 0.0
      rotation:
        v:
          x: 0.0
          y: 0.0
          z: 0.0
        s: 1.0
      rotation_euler:
        x: 0.0
        y: 0.0
        z: 0.0
      scale:
        x: 1.0
        y: 1.0
        z: 1.0
      up:
        x: 0.0
        y: 1.0
        z: 0.0
      forward:
        x: 0.0
        y: 0.0
        z: -1.0
      right:
        x: 1.0
        y: 0.0
        z: 0.0
      global_position:
        x: 0.0
        y: 0.0
        z: 0.0
      global_rotation:
        v:
          x: 0.0
          y: 0.0
          z: 0.0
        s: 1.0
      global_scale:
        x: 1.0
        y: 1.0
        z: 1.0
  children: []
name: Scene
path: res/scene.scene
is_primary: false
