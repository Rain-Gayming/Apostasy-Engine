root_children:
- name: Skybox
  id: 0
  components:
  - type: Transform
    data:
      position:
        x: 0.0
        y: 0.0
        z: 0.0
      rotation:
        v:
          x: 0.0
          y: 0.0
          z: 0.0
        s: 1.0
      rotation_euler:
        x: 0.0
        y: 0.0
        z: 0.0
      scale:
        x: 1.0
        y: 1.0
        z: 1.0
      up:
        x: 0.0
        y: 1.0
        z: 0.0
      forward:
        x: 0.0
        y: 0.0
        z: -1.0
      right:
        x: 1.0
        y: 0.0
        z: 0.0
      global_position:
        x: 0.0
        y: 0.0
        z: 0.0
      global_rotation:
        v:
          x: 0.0
          y: 0.0
          z: 0.0
        s: 1.0
      global_scale:
        x: 1.0
        y: 1.0
        z: 1.0
  - type: Skybox
    data:
      texture_path: .engine/default_skybox_texture.png
  children: []
  parent: null
  scene_instance_path: null
- name: Directional Light
