        x: 0.0
        y: 5.0
        z: 10.0
      global_rotation:
        v:
          x: 0.0
          y: 0.0
          z: 0.0
        s: 1.0
      global_scale:
        x: 1.0
        y: 1.0
        z: 1.0
  - type: Player
    data:
      is_active: true
      wish_dir:
        x: 0.0
        y: 0.0
        z: 0.0
      jump_pressed: false
      previous_jump_pressed: false
  - type: Velocity
    data:
      direction:
        x: 0.0
        y: 0.0
        z: 0.0
      angular_direction:
        x: 0.0
        y: 0.0
        z: 0.0
      time_since_ground: 0.0
      is_grounded: false
  - type: PhysicsBody
    data:
      mass: 1.0
      friction: 150.0
      drag: 0.05000000074505806
      bounce: 0.0
      gravity: -9.8100004196167
      is_gravity_enabled: true
      linear_damping: 0.05000000074505806
      angular_damping: 0.10000000149011612
  - type: MovementStats
    data:
      current_speed: 10.0
      walk_speed: 190.0
      run_speed: 100.0
      sprint_speed: 400.0
      jump_speed: 5.0
  - type: Collider
    data:
      shape: !Capsule
        radius: 0.75
        height: 2.75
      offset:
        x: 0.0
        y: 0.0
        z: 0.0
      is_static: false
      is_area: false
  - type: ModelRenderer
    data:
      loaded_model: models/capsule.glb
      material_path: ''
  children:
  - name: Camera
    id: 3
    components:
    - type: Transform
      data:
        position:
          x: 0.0
          y: 1.5
          z: 0.0
        rotation:
          v:
            x: 0.0
            y: 0.0
            z: 0.0
          s: 1.0
        rotation_euler:
          x: 0.0
          y: 0.0
          z: 0.0
        scale:
          x: 1.0
          y: 1.0
          z: 1.0
        up:
          x: 0.0
          y: 1.0
          z: 0.0
        forward:
          x: 0.0
          y: 0.0
          z: -1.0
        right:
          x: 1.0
          y: 0.0
          z: 0.0
        global_position:
          x: 0.0
          y: 6.5
          z: 10.0
        global_rotation:
          v:
            x: 0.0
            y: 0.0
            z: 0.0
          s: 1.0
        global_scale:
          x: 1.0
          y: 1.0
          z: 1.0
    - type: Camera
      data:
        fov_y: 90.0
        near: 0.0010000000474974513
        far: 10000.0
    children: []
    parent: null
    scene_instance_path: null
  parent: null
  scene_instance_path: null
