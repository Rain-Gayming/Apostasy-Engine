- name: Player
  id: 2
  components:
  - type: Transform
    data:
      position:
        x: 0.0
        y: 5.0
        z: 10.0
      rotation:
        v:
          x: 0.0
          y: 0.0
          z: 0.0
        s: 1.0
      rotation_euler:
        x: 0.0
        y: 0.0
        z: 0.0
      scale:
        x: 1.0
        y: 1.0
        z: 1.0
      up:
        x: 0.0
        y: 1.0
        z: 0.0
